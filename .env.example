# Do not commit a populated .env file.
# This domain-core repository has no network service configured by default.

# Optional local paths. Use absolute, user-writable directories in production.
TALLY_IMPORT_TEMP_ROOT=
TALLY_ARCHIVE_ROOT=

# Archive encryption keys must be injected from secure device/server storage,
# never checked into this file or placed in application logs.
TALLY_ARCHIVE_KEY=

# Reserved for the future API host. Keep disabled until endpoint middleware,
# authenticated identity verification, and a shared rate-limit store exist.
TALLY_TELEMETRY_ENABLED=false
TALLY_RATE_LIMIT_ENABLED=false
